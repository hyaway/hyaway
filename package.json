{
  "name": "hyaway-app",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:host": "vite --port 3000 --host",
    "dev:ts": "tailscale serve --bg 3000",
    "dev:ts:off": "tailscale serve 3000 off",
    "build": "vite build",
    "serve": "vite preview",
    "docker": "docker compose -f docker/docker-compose.build.yml up -d --build",
    "docker:attach": "docker compose -f docker/docker-compose.build.yml up --build",
    "docker:stop": "docker compose -f docker/docker-compose.build.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.build.yml logs -f",
    "docker:pull": "docker compose -f docker/docker-compose.yml up -d",
    "docker:pull:update": "docker compose -f docker/docker-compose.yml pull && docker compose -f docker/docker-compose.yml up -d",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:dev:attach": "docker compose -f docker/docker-compose.dev.yml up",
    "docker:ts": "tailscale serve --bg 4929",
    "docker:ts:off": "tailscale serve 4929 off",
    "ts:status": "tailscale serve status",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check": "prettier --write . && eslint --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "licenses": "pnpx license-checker-rseidelsohn --production --relativeLicensePath --relativeModulePath --out NOTICE --nopeer --excludePrivatePackage --csv",
    "ref:update": "git -C .reference/hydrus fetch --depth 1 && git -C .reference/hydrus reset --hard origin/master",
    "ref:clone": "git clone --depth 1 https://github.com/hydrusnetwork/hydrus.git .reference/hydrus"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@react-querybuilder/core": "8.16.1",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-form": "1.32.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-virtual": "^3.13.24",
    "@vidstack/react": "^1.12.13",
    "axios": "^1.16.1",
    "blurhash": "^2.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lodash.memoize": "^4.1.2",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-querybuilder": "^8.16.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "slug": "^11.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul-base": "^1.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/react-vite": "^10.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@tanstack/router-cli": "^1.166.43",
    "@tanstack/router-plugin": "^1.167.35",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash.memoize": "^4.1.9",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/slug": "^5.0.9",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-storybook": "10.4.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.7.0",
    "storybook": "^10.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-tsconfig-paths": "^6.1.1",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.1.6",
    "web-vitals": "^5.2.0"
  },
  "browserslist": [
    "baseline widely available"
  ]
}
